---
import PhotoDepthFieldBackground from "../components/PhotoDepthFieldBackground";

interface Props {
	title?: string;
	description?: string;
}

const { title = "台湾AI男子", description } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sawarabi+Gothic&family=Shippori+Mincho:wght@400;700&display=swap" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<title>{title}</title>
	</head>
	<body class="relative min-h-screen overflow-x-hidden bg-white text-black">
		<div class="fixed inset-0 z-0 pointer-events-none w-full h-full">
			<PhotoDepthFieldBackground client:only="react" />
		</div>
		<div class="relative z-10 overflow-x-hidden lg:overflow-visible">
			<slot />
		</div>
	</body>
</html>
