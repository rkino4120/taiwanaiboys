---
import PhotoDepthFieldBackground from "../../components/PhotoDepthFieldBackground";

interface Props {
	title?: string;
	description?: string;
}

const { title = "台灣AI男子", description } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700&family=Noto+Serif+TC:wght@400;700&display=swap" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<title>{title}</title>
	</head>
	<body class="relative min-h-screen overflow-x-hidden bg-white text-black">
		<div style="position:fixed;inset:0;z-index:0;pointer-events:none;width:100%;height:100%;">
			<PhotoDepthFieldBackground client:only="react" />
		</div>
		<div class="relative z-10">
			<slot />
		</div>
	</body>
</html>
