---
import { Font } from "astro:assets";
import PhotoDepthFieldBackground from "../../components/PhotoDepthFieldBackground";

interface Props {
	title?: string;
	description?: string;
}

const { title = "台灣AI男子", description } = Astro.props;
---

<!doctype html>
<html lang="zh-Hant">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<title>{title}</title>
		<Font cssVariable="--font-noto-sans-tc" preload />
		<Font cssVariable="--font-noto-serif-tc" preload />
	</head>
	<body class="relative min-h-screen overflow-x-hidden bg-white text-black">
		<div style="position:fixed;inset:0;z-index:0;pointer-events:none;width:100%;height:100%;">
			<PhotoDepthFieldBackground client:only="react" />
		</div>
		<div class="relative z-10">
			<slot />
		</div>
	</body>
</html>
